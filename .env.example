# Project Slick - Environment Variables

# The active Hyperliquid Wallet Address and Private Secret Key for trading
HYPERLIQUID_WALLET=0xYourWalletAddressHere
HYPERLIQUID_SECRET=YourSecretKeyHere

# Gemini API Key for any multimodal scoring usage in the Orchestrator
GEMINI_API_KEY=AIzaSyYourGeminiKeyHere

# Local PostgreSQL TimescaleDB Connection
DATABASE_URL=postgresql://postgres:postgres@timescale:5432/slick_ts

# Microservice internal URLs (for decouple running)
ORCHESTRATOR_URL=http://localhost:8000/orchestrator
QUANT_URL=http://localhost:8000/quant
